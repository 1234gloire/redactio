# REDACTIO production environment for redactio.evc-pae.fr
NODE_ENV=production
HOST=127.0.0.1
PORT=3121

# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-production-secret

# Bootstrap admin. Replace after first deployment if needed.
LOCAL_ADMIN_EMAIL=gloirerofie@gmail.com
LOCAL_ADMIN_PASSWORD=replace-with-a-strong-production-password
LOCAL_ADMIN_NAME=Gloire Rofie

# Dedicated REDACTIO database on the VPS.
MYSQL_DATABASE=redactio
MYSQL_USER=redactio
MYSQL_PASSWORD=replace-with-a-strong-db-password
DATABASE_URL=mysql://redactio:replace-with-a-strong-db-password@127.0.0.1:3306/redactio

# Optional AI provider/proxy values. Leave empty until configured.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Optional analytics.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
